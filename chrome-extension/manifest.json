{
  "manifest_version": 3,
  "name": "AI Task Hub — ChatGPT Monitor",
  "description": "偵測 ChatGPT 圖片生成狀態，回報給本機 AI Task Hub (localhost:9999)，並自動下載生成圖片",
  "version": "0.2.0",
  "permissions": ["storage"],
  "host_permissions": [
    "http://localhost:9999/*",
    "https://*.oaiusercontent.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
